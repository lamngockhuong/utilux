---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CopyButton from '../../components/CopyButton.astro';

const installCommand = 'curl -fsSL https://raw.githubusercontent.com/lamngockhuong/utilux/main/install.sh | bash';
---

<BaseLayout title="Documentation">
  <section class="py-12">
    <div class="container max-w-3xl">
      <h1 class="text-3xl font-bold mb-8">Documentation</h1>

      <nav class="bg-slate-800/50 rounded-lg p-4 mb-8">
        <h2 class="font-semibold mb-2 text-slate-300">Contents</h2>
        <ul class="space-y-1 text-blue-400">
          <li><a href="#installation" class="hover:text-blue-300">Installation</a></li>
          <li><a href="#usage" class="hover:text-blue-300">Usage</a></li>
          <li><a href="#commands" class="hover:text-blue-300">Commands</a></li>
          <li><a href="#go-cli" class="hover:text-blue-300">Go CLI (Optional)</a></li>
          <li><a href="#configuration" class="hover:text-blue-300">Configuration</a></li>
          <li><a href="#contributing" class="hover:text-blue-300">Contributing</a></li>
        </ul>
      </nav>

      <!-- Installation -->
      <section id="installation" class="mb-12">
        <h2 class="text-2xl font-bold mb-4">Installation</h2>
        <p class="text-slate-300 mb-4">Install Utilux with a single command:</p>
        <div class="bg-slate-800 rounded-lg p-4 mb-4">
          <div class="flex items-center gap-2">
            <code class="flex-1 text-emerald-400 font-mono text-sm">{installCommand}</code>
            <CopyButton text={installCommand} />
          </div>
        </div>
        <p class="text-slate-400 text-sm">Requirements: bash, curl</p>
      </section>

      <!-- Usage -->
      <section id="usage" class="mb-12">
        <h2 class="text-2xl font-bold mb-4">Usage</h2>
        <p class="text-slate-300 mb-4">Utilux uses lazy loading - scripts are downloaded on first use and cached locally.</p>

        <div class="space-y-4">
          <div class="bg-slate-800 rounded-lg p-4">
            <p class="text-slate-400 text-sm mb-2"># Launch interactive TUI menu</p>
            <code class="text-emerald-400">utilux</code>
          </div>

          <div class="bg-slate-800 rounded-lg p-4">
            <p class="text-slate-400 text-sm mb-2"># List all available scripts</p>
            <code class="text-emerald-400">utilux list</code>
          </div>

          <div class="bg-slate-800 rounded-lg p-4">
            <p class="text-slate-400 text-sm mb-2"># Run a script</p>
            <code class="text-emerald-400">utilux run git-clean</code>
          </div>

          <div class="bg-slate-800 rounded-lg p-4">
            <p class="text-slate-400 text-sm mb-2"># Search for scripts</p>
            <code class="text-emerald-400">utilux search docker</code>
          </div>

          <div class="bg-slate-800 rounded-lg p-4">
            <p class="text-slate-400 text-sm mb-2"># Get script info</p>
            <code class="text-emerald-400">utilux info disk-cleanup</code>
          </div>
        </div>
      </section>

      <!-- Commands -->
      <section id="commands" class="mb-12">
        <h2 class="text-2xl font-bold mb-4">Commands</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-slate-700">
                <th class="py-2 pr-4">Command</th>
                <th class="py-2">Description</th>
              </tr>
            </thead>
            <tbody class="text-slate-300">
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">run &lt;script&gt;</td>
                <td class="py-2">Run a script (downloads on first use)</td>
              </tr>
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">list [category]</td>
                <td class="py-2">List available scripts</td>
              </tr>
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">search &lt;query&gt;</td>
                <td class="py-2">Search scripts by name/description</td>
              </tr>
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">info &lt;script&gt;</td>
                <td class="py-2">Show script details</td>
              </tr>
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">update [--all]</td>
                <td class="py-2">Update cached scripts</td>
              </tr>
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">cache list|clear|size</td>
                <td class="py-2">Manage local cache</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 font-mono text-sm">config [key] [value]</td>
                <td class="py-2">View/set configuration</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Go CLI -->
      <section id="go-cli" class="mb-12">
        <h2 class="text-2xl font-bold mb-4">Go CLI (Optional)</h2>
        <p class="text-slate-300 mb-4">For better performance, you can use the Go-based CLI. It's a single binary with no dependencies.</p>

        <h3 class="font-semibold mt-6 mb-2">Advantages over Bash CLI</h3>
        <ul class="list-disc list-inside space-y-1 text-slate-300 mb-4">
          <li>Single binary - no interpreter needed</li>
          <li>Faster startup time (~ms vs ~100ms)</li>
          <li>Native concurrency for parallel downloads</li>
          <li>Rich TUI with Bubbletea framework</li>
          <li>Cross-platform binaries available</li>
        </ul>

        <h3 class="font-semibold mt-6 mb-2">Installation</h3>
        <div class="space-y-4">
          <div class="bg-slate-800 rounded-lg p-4">
            <p class="text-slate-400 text-sm mb-2"># Build from source (requires Go 1.21+)</p>
            <code class="text-emerald-400">cd cli && go build -o utilux-go .</code>
          </div>
          <div class="bg-slate-800 rounded-lg p-4">
            <p class="text-slate-400 text-sm mb-2"># Or download pre-built binary</p>
            <code class="text-emerald-400">curl -fsSL https://github.com/lamngockhuong/utilux/releases/latest/download/utilux-go-linux-amd64 -o utilux-go</code>
          </div>
        </div>
      </section>

      <!-- Configuration -->
      <section id="configuration" class="mb-12">
        <h2 class="text-2xl font-bold mb-4">Configuration</h2>
        <p class="text-slate-300 mb-4">Configuration is stored in <code class="bg-slate-800 px-1 rounded">~/.utilux/config</code></p>

        <h3 class="font-semibold mt-6 mb-2">Environment Variables</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-slate-700">
                <th class="py-2 pr-4">Variable</th>
                <th class="py-2">Description</th>
              </tr>
            </thead>
            <tbody class="text-slate-300">
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">UTILUX_OFFLINE</td>
                <td class="py-2">Enable offline mode (use cached only)</td>
              </tr>
              <tr class="border-b border-slate-800">
                <td class="py-2 pr-4 font-mono text-sm">UTILUX_LOG_LEVEL</td>
                <td class="py-2">Log level: debug, info, warn, error</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 font-mono text-sm">UTILUX_CACHE_DIR</td>
                <td class="py-2">Custom cache directory</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Contributing -->
      <section id="contributing" class="mb-12">
        <h2 class="text-2xl font-bold mb-4">Contributing</h2>
        <p class="text-slate-300 mb-4">Want to add a script? Contributions are welcome!</p>

        <ol class="list-decimal list-inside space-y-2 text-slate-300">
          <li>Fork the repository</li>
          <li>Create your script in <code class="bg-slate-800 px-1 rounded">registry/&lt;category&gt;/</code></li>
          <li>Add script metadata header</li>
          <li>Run <code class="bg-slate-800 px-1 rounded">./scripts/generate-manifest.sh</code></li>
          <li>Submit a pull request</li>
        </ol>

        <h3 class="font-semibold mt-6 mb-2">Script Template</h3>
        <pre class="bg-slate-800 rounded-lg p-4 text-sm overflow-x-auto"><code class="text-emerald-400">#!/bin/bash
# @name: script-name
# @version: v1.0.0
# @description: Brief description
# @category: dev
# @requires: git, curl
# @tags: tag1, tag2
# @author: your-name

set -euo pipefail

main() &#123;
  # Your code here
&#125;

main "$@"</code></pre>
      </section>

      <div class="border-t border-slate-700 pt-6">
        <a href="https://github.com/lamngockhuong/utilux" target="_blank" rel="noopener" class="text-blue-400 hover:text-blue-300">
          View on GitHub &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
