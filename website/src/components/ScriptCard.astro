---
interface Props {
  name: string;
  description: string;
  category: string;
  tags?: string[];
}

const { name, description, category, tags = [] } = Astro.props;

const categoryColors: Record<string, string> = {
  system: 'bg-blue-500/20 text-blue-400',
  dev: 'bg-green-500/20 text-green-400',
  automation: 'bg-purple-500/20 text-purple-400',
  network: 'bg-orange-500/20 text-orange-400',
};
---

<a
  href={`/catalog/${name}`}
  class="block p-5 bg-slate-800/50 hover:bg-slate-800 border border-slate-700 hover:border-slate-600 rounded-lg transition group"
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-semibold text-lg text-white group-hover:text-blue-400 transition">
      {name}
    </h3>
    <span class:list={["px-2 py-0.5 rounded text-xs font-medium", categoryColors[category] || 'bg-slate-700 text-slate-300']}>
      {category}
    </span>
  </div>

  <p class="text-slate-400 text-sm mb-3 line-clamp-2">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {tags.map(tag => (
        <span class="px-2 py-0.5 bg-slate-700/50 text-slate-400 rounded text-xs">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
